<%= @error_report.severity.upcase %>: <%= @error_report.error_class %>
<%= @error_report.message %>

Severity: <%= @error_report.severity %>
Source: <%= @error_report.source %>
Time: <%= @error_report.created_at.to_formatted_s(:default) %>
<% if @error_report.request_url.present? -%>
URL: <%= @error_report.request_method %> <%= @error_report.request_url %>
<% end -%>
<% if @error_report.ip_address.present? -%>
IP: <%= @error_report.ip_address %>
<% end -%>
<% if @error_report.user_id.present? -%>
User: #<%= @error_report.user_id %>
<% end -%>
<% if @error_report.backtrace.present? %>
Backtrace:
<%= @error_report.backtrace %>
<% end %>
